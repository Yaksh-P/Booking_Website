{
  "name": "booking_web_application",
  "version": "1.0.0",
  "description": "Backend API for a booking website final project",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test --test-isolation=none --experimental-test-coverage --test-coverage-exclude=dist/tests/** --test-coverage-exclude=dist/src/index.js dist/tests/**/*.test.js",
    "test:ts-coverage": "c8 --reporter=text --reporter=html --all --include=src/**/*.ts --exclude=src/index.ts --exclude=src/app.ts --exclude=src/routes/** --exclude=src/entities/** --exclude=tests/** tsx --test --test-isolation=none tests/**/*.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "c8": "^10.1.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
